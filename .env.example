# Database
DATABASE_URL=postgresql+asyncpg://rozkaana:password@localhost:5432/rozkaana
DATABASE_URL_SYNC=postgresql+psycopg2://rozkaana:password@localhost:5432/rozkaana

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=your-256-bit-random-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=rozkaana-pdfs
MINIO_SECURE=false

# WATI WhatsApp
WATI_API_BASE_URL=https://live-mt-server.wati.io/{your_account_id}
WATI_ACCESS_TOKEN=Bearer eyJ...
WATI_WEBHOOK_SECRET=your_webhook_verification_secret

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# MSG91 (OTP)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_otp_template_id
MSG91_SENDER_ID=NUTRSV

# OpenAI (admin recipe generation only)
OPENAI_API_KEY=sk-your-openai-key

# App
APP_BASE_URL=https://your-cloudflare-tunnel-url.trycloudflare.com
PDF_PRESIGNED_URL_EXPIRE_HOURS=12

# Scheduling (UTC times)
MENU_GEN_HOUR_UTC=18
PDF_BUILD_HOUR_UTC=22
WA_SEND_HOUR_UTC=0

# ── Zoho Mail SMTP ──────────────────────────────────────────
# Get App Password from: mail.zoho.in → Settings → Security → App Passwords
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_USER=noreply@rozkaana.in
SMTP_PASSWORD=your-zoho-app-password
SMTP_FROM_NAME=Rozkaana
SMTP_FROM_EMAIL=noreply@rozkaana.in
SMTP_MENU_USER=menu@rozkaana.in
SMTP_MENU_PASSWORD=password-for-menu-user
